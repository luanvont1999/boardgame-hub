{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n \"NODE,VITE\" -c \"cyan.bold,yellow.bold\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch api/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "check": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json",
    "deploy:vercel": "npm run build && npx firebase deploy --only hosting:$VERCEL_ENV --token \"$FIREBASE_TOKEN\""
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "firebase-tools": "^15.24.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "dotenv": "^16.4.7",
    "firebase": "^12.15.0",
    "hono": "^4.6.20",
    "jsonwebtoken": "^9.0.2",
    "mapbox-gl": "^3.25.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
